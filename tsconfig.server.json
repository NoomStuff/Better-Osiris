{
   "compilerOptions": {
      "target": "es2023",
      "module": "esnext",
      "lib": ["ES2023"],
      "types": ["node"],
      "skipLibCheck": true,
      "moduleResolution": "bundler",
      "verbatimModuleSyntax": true,
      "moduleDetection": "force",
      "noEmit": true,
      "strict": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noFallthroughCasesInSwitch": true
   },
   "include": ["server.ts", "server/**/*.ts", "api/**/*.ts"]
}
