{
   "name": "Better-Osiris",
   "private": true,
   "version": "1.2.0",
   "type": "module",
   "scripts": {
      "dev": "bun scripts/ensureDevCookieSecret.ts && concurrently --kill-others-on-fail \"cross-env NODE_ENV=development bun --watch server.ts\" \"bunx vite\"",
      "server": "bun scripts/ensureDevCookieSecret.ts && cross-env NODE_ENV=development bun server.ts",
      "build": "bunx tsc -p tsconfig.json && bunx tsc -p tsconfig.server.json && bunx vite build",
      "lint": "eslint . --max-warnings 0",
      "test": "concurrently \"bun run test:unit\" \"bun run test:e2e\"",
      "test:unit": "bun test",
      "test:e2e": "playwright test",
      "serve": "bunx vite preview",
      "start": "cross-env NODE_ENV=production bun server.ts",
      "format": "prettier --write .",
      "format:check": "prettier --check .",
      "verify": "bun run format:check && concurrently \"bun run lint\" \"bun run test\" \"bun run build\""
   },
   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@axe-core/playwright": "^4.12.1",
      "@playwright/test": "^1.61.1",
      "@types/express": "^5.0.6",
      "@types/node": "^26.1.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "concurrently": "^10.0.3",
      "@types/compression": "^1.8.1",
      "cross-env": "^10.1.0",
      "eslint": "^10.7.0",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-react-refresh": "^0.5.3",
      "globals": "^17.7.0",
      "prettier": "^3.9.5",
      "typescript": "~6.0.3",
      "typescript-eslint": "^8.64.0",
      "vite": "^8.1.4"
   },
   "dependencies": {
      "@fontsource-variable/quicksand": "^5.2.10",
      "@fortawesome/fontawesome-free": "^7.3.0",
      "compression": "^1.8.1",
      "express": "^5.2.1",
      "notyf": "^3.10.0",
      "react": "^19.2.7",
      "react-dom": "^19.2.7"
   },
   "overrides": {
      "@babel/core": "8.0.1",
      "brace-expansion": "5.0.7",
      "qs": "6.15.3"
   }
}
