# Required: used to encrypt bearer tokens stored in browser cookies.
# `bun run dev` replaces this public placeholder with a secure local value.
COOKIE_SECRET="replace-with-at-least-32-cryptographically-random-characters"

# Required: the full OSIRIS weekly roster endpoint.
OSIRIS_ROSTER_URL="https://mborijnland.osiris-student.nl/student/osiris/student/rooster/per_week"

# Optional: displayed above "Better Osiris" when set.
# SCHOOL_NAME="MBORijnland"

# Optional: enable only when the standalone server is behind a trusted reverse proxy.
# The rightmost X-Forwarded-For address will be used for rate limiting.
# TRUST_PROXY=true

# Optional: a shared token when users do not enter their own. Recommended for local testing, not in prod.
# BEARER_TOKEN=Bearer XXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required in production when BEARER_TOKEN is intentionally shared with every visitor.
# ALLOW_SHARED_BEARER_TOKEN=true
